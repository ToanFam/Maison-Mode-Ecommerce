POSTGRES_DB=fashion_commerce
POSTGRES_USER=fashion_user
POSTGRES_PASSWORD=replace-with-a-strong-password
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/fashion_commerce
# Optional for Render/Railway-style managed databases. Used only when SPRING_DATASOURCE_URL is blank.
# DATABASE_URL=postgresql://user:password@host:5432/fashion_commerce
SERVER_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=update
JWT_SECRET=replace-with-at-least-32-random-characters-change-me
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=https://your-domain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=120
RATE_LIMIT_WINDOW_SECONDS=60
VITE_API_URL=https://api.your-domain.com/api
